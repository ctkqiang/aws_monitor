{
  "expo": {
    "name": "AWSight",
    "slug": "awsight",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/applogo.png",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#1a1a2e",
    "splash": {
      "image": "./assets/applogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "xin.ctkqiang.awsight",
      "associatedDomains": [
        "webcredentials:awsight.app",
        "webcredentials:awsight.app"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/applogo.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "xin.ctkqiang.awsight",
      "allowBackup": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "awsight.app",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/applogo.png"
    },
    "extra": {
      "eas": {
        "projectId": "85d375f2-2cde-4303-be83-203dbbde9da0"
      }
    }
  }
}
